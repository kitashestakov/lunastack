{
  "permissions": {
    "allow": [
      "mcp__claude_ai_Notion__notion-search",
      "mcp__claude_ai_Notion__notion-fetch",
      "mcp__claude_ai_Notion__notion-create-pages",
      "mcp__claude_ai_Notion__notion-update-page",
      "mcp__claude_ai_Notion__notion-get-comments",
      "mcp__claude_ai_Notion__notion-create-comment",
      "mcp__claude_ai_Notion__notion-get-users",
      "mcp__claude_ai_Notion__notion-query-database-view",
      "WebSearch",
      "WebFetch",
      "Bash(scripts/huntflow.sh *)",
      "Bash(scripts/tldv.sh *)",
      "Bash(cat ~/.luna-stack/config.yaml)",
      "Bash(git pull)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git push --dry-run *)",
      "Bash(git push origin main)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(mkdir -p ~/.luna-stack)",
      "Bash(mkdir -p ~/.luna-stack/*)",
      "Bash(tee ~/.luna-stack/config.yaml *)",
      "Bash(ffmpeg *)",
      "Bash(whisper-cli *)",
      "Bash(command -v *)",
      "Bash(ls ~/.luna-stack/*)",
      "Bash(cat ~/.luna-stack/tmp/*)",
      "Bash(brew install *)",
      "Bash(brew --version)",
      "Bash(curl -L -o ~/.luna-stack/whisper/* *)",
      "Bash(curl -I https://huggingface.co)",
      "Edit(/.claude/skills/vacancy/**)",
      "Edit(/.claude/skills/screening/**)",
      "Edit(/.claude/skills/briefing/**)"
    ],
    "deny": [
      "mcp__claude_ai_Notion__notion-create-database",
      "mcp__claude_ai_Notion__notion-update-data-source",
      "mcp__claude_ai_Notion__notion-create-view",
      "mcp__claude_ai_Notion__notion-update-view",
      "mcp__claude_ai_Notion__notion-duplicate-page",
      "mcp__claude_ai_Notion__notion-move-pages",
      "Bash(rm *)",
      "Bash(git push -f *)",
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset *)",
      "Bash(git checkout *)",
      "Bash(wget *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "api.huntflow.ai",
        "github.com",
        "huggingface.co",
        "cdn-lfs.huggingface.co",
        "cdn-lfs-us-1.huggingface.co",
        "formulae.brew.sh",
        "ghcr.io",
        "pkg-containers.githubusercontent.com",
        "objects.githubusercontent.com",
        "raw.githubusercontent.com",
        "pasta.tldv.io",
        "api.tldv.io",
        "tldv.io"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.luna-stack"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.config/gcloud",
        "~/Documents",
        "~/Desktop",
        "~/.env",
        "~/.zshrc",
        "~/.bashrc",
        "~/.bash_profile",
        "~/.netrc",
        "~/.npmrc"
      ],
      "allowRead": [
        "~/.luna-stack",
        "~/Downloads"
      ]
    }
  }
}
